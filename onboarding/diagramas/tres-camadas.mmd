%%{init: {"theme":"dark", "flowchart": {"htmlLabels": true, "curve": "basis", "padding": 18, "nodeSpacing": 45, "rankSpacing": 55}}}%%
flowchart LR
subgraph C1["LAYER 1 · PRETOOL"]
  direction TB
  a1["WHEN<br/>before execution"]
  a2["WHERE<br/>userspace · synchronous"]
  a3["DOES<br/>scans and denies with exit 2"]
  a4["CATCHES<br/>hostile action or command<br/>at the moment it tries to execute"]
  a1 --- a2 --- a3 --- a4
end
subgraph C2["LAYER 2 · DAEMON"]
  direction TB
  b1["WHEN<br/>post-action · background"]
  b2["WHERE<br/>userspace · asynchronous"]
  b3["DOES<br/>moves the file to quarantine"]
  b4["CATCHES<br/>malware that reached disk<br/>reversible: restore or purge"]
  b1 --- b2 --- b3 --- b4
end
subgraph C3["LAYER 3 · eBPF"]
  direction TB
  c1["WHEN<br/>if the pretool is bypassed"]
  c2["WHERE<br/>kernel · Linux · opt-in"]
  c3["DOES<br/>denies with -EPERM in the kernel"]
  c4["CATCHES<br/>agent exec + egress<br/>scoped by the agent cgroup"]
  c1 --- c2 --- c3 --- c4
end
C1 ==> C2 ==> C3
NOTE["Independent layers: if one fails, the next holds.<br/>L1 and L2 share the same engine. Defense = sum of layers (the coefficient).<br/>On macOS, L1 + L2 is the design; eBPF is Linux reinforcement."]
C3 -.-> NOTE

