          "id": "rust-001",
          "pattern": "\\.unwrap\\s*\\(\\)\\s*\\.\\s*[a-z_]+\\s*\\(\\)\\s*\\.\\s*unwrap\\s*\\(\\)\\s*\\.\\s*[a-z_]+\\s*\\(\\)\\s*\\.\\s*unwrap",
          "type": "regex",
