#[derive(Debug, Clone, Serialize, Deserialize)]
struct NemesisReport {
    inventory: Inventory,
    blocking_patterns: Vec<BlockingPattern>,
    smart_components: Vec<SmartComponent>,
    benefits: Benefits,
    metrics: Metrics,
}

#[derive(Debug, Clone, Serialize, Deserialize)]
struct Inventory {
    files: Vec<FileInfo>,
    total_files: usize,
    total_size: u64,
}

#[derive(Debug, Clone, Serialize, Deserialize)]
struct FileInfo {
    path: String,
    size: u64,
    #[serde(rename = "type")]
    file_type: String,
    lines: Option<usize>,
}

#[derive(Debug, Clone, Serialize, Deserialize)]
struct BlockingPattern {
    category: String,
    pattern: String,
    source: String,
    description: String,
}

#[derive(Debug, Clone, Serialize, Deserialize)]
struct SmartComponent {
    path: String,
    #[serde(rename = "type")]
    component_type: String,
}

#[derive(Debug, Clone, Serialize, Deserialize)]
struct Benefits {
    development: Vec<String>,
    user: Vec<String>,
    business: Vec<String>,
    performance: Vec<String>,
    security: Vec<String>,
}

#[derive(Debug, Clone, Serialize, Deserialize)]
struct Metrics {
    total_patterns: usize,
    security_patterns: usize,
    performance_patterns: usize,
    architecture_patterns: usize,
    protected_files: usize,
    smart_components: usize,
}

struct NemesisAnalyzer {
    project_root: PathBuf,
    nemesis_dir: PathBuf,
    windsurf_dir: PathBuf,
    report: NemesisReport,
}

impl NemesisAnalyzer {
    fn new() -> Self {
        let project_root = env::current_dir().unwrap_or_else(|_| PathBuf::from("."));
        Self {
            nemesis_dir: project_root.join(".nemesis"),
            windsurf_dir: project_root.join(".windsurf"),
            project_root,
            report: Self::initialize_report(),
        }
    }

    fn initialize_report() -> NemesisReport {
        NemesisReport {
            inventory: Inventory {
                files: Vec::new(),
                total_files: 0,
                total_size: 0,
            },
            blocking_patterns: Vec::new(),
            smart_components: Vec::new(),
            benefits: Benefits {
                development: Vec::new(),
                user: Vec::new(),
                business: Vec::new(),
                performance: Vec::new(),
                security: Vec::new(),
            },
            metrics: Metrics {
                total_patterns: 0,
                security_patterns: 0,
                performance_patterns: 0,
                architecture_patterns: 0,
                protected_files: 0,
                smart_components: 0,
            },
        }
