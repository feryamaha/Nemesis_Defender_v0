        let sh_files = self.report.inventory.files.iter().filter(|f| f.file_type == ".sh").count();
        let json_files = self.report.inventory.files.iter().filter(|f| f.file_type == ".json").count();

        let main_files: Vec<_> = self.report.inventory.files.iter()
            .filter(|f| f.path.contains("workflow-enforcement") || f.path.contains("hook") || f.path.contains("validator"))
            .map(|f| format!("- **{}** ({} linhas, {:.2} KB)", f.path, f.lines.unwrap_or(0), f.size as f64 / 1024.0))
            .collect();

        let security_patterns: Vec<_> = self.report.blocking_patterns.iter()
            .filter(|p| p.category == "Segurança")
            .take(10)
            .map(|p| format!("- **{}** - {} ({})", p.pattern, p.description, p.source))
            .collect();

        let security_extra = self.report.blocking_patterns.iter().filter(|p| p.category == "Segurança").count().saturating_sub(10);

        let performance_patterns: Vec<_> = self.report.blocking_patterns.iter()
            .filter(|p| p.category == "Performance")
            .map(|p| format!("- **{}** - {} ({})", p.pattern, p.description, p.source))
            .collect();

        let architecture_patterns: Vec<_> = self.report.blocking_patterns.iter()
            .filter(|p| p.category == "Arquitetura")
            .map(|p| format!("- **{}** - {} ({})", p.pattern, p.description, p.source))
            .collect();

        let component_counts: HashMap<&str, usize> = self.report.smart_components.iter()
            .fold(HashMap::new(), |mut acc, comp| {
                *acc.entry(&comp.component_type).or_insert(0) += 1;
                acc
            });

        let component_dist: Vec<_> = component_counts.iter()
            .map(|(t, c)| format!("- **{}:** {} componentes", t, c))
            .collect();

        let components_list: Vec<_> = self.report.smart_components.iter()
            .take(10)
            .map(|c| format!("- **{}** ({})", c.path, c.component_type))
