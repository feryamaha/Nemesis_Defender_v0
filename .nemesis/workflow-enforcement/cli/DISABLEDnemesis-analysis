    fn analyze_nemesis_structure(&mut self) {
        println!("🔍 Analisando estrutura do Nemesis...");

        let result = Command::new("find")
            .args(&[
                &self.nemesis_dir.to_string_lossy(),
                "-type", "f", "(", "-name", "*.ts", "-o", "-name", "*.js",
                "-o", "-name", "*.sh", "-o", "-name", "*.json",
                "-o", "-name", "*.toml", "-o", "-name", "*.md", ")",
            ])
            .output();

        match result {
            Ok(output) if output.status.success() => {
                let files: Vec<_> = String::from_utf8_lossy(&output.stdout)
                    .lines()
                    .filter(|l| !l.is_empty())
                    .map(|s| s.to_string())
                    .collect();

                for file_path in &files {
                    if let Ok(stats) = fs::metadata(file_path) {
                        if let Ok(content) = fs::read_to_string(file_path) {
                            let lines = content.lines().count();
                            let relative_path = PathBuf::from(file_path)
                                .strip_prefix(&self.project_root)
                                .map(|p| p.to_string_lossy().to_string())
                                .unwrap_or_else(|_| file_path.clone());

                            self.report.inventory.files.push(FileInfo {
                                path: relative_path,
                                size: stats.len(),
                                file_type: PathBuf::from(file_path)
                                    .extension()
                                    .and_then(|e| e.to_str())
                                    .map(|s| format!(".{}", s))
                                    .unwrap_or_default(),
                                lines: Some(lines),
                            });

                            self.report.inventory.total_size += stats.len();
                        }
                    }
                }

                self.report.inventory.total_files = self.report.inventory.files.len();
                println!("✅ Encontrados {} arquivos Nemesis", self.report.inventory.total_files);
            }
            _ => {
                println!("⚠️  Aviso: Não foi possível listar arquivos Nemesis");
            }
        }
    }

    fn extract_blocking_patterns(&mut self) {
        println!("🔍 Extraindo patterns de bloqueio...");

        let enforcer_path = self.nemesis_dir
            .join("workflow-enforcement")
            .join("workflow-enforcer.rs");

        if !enforcer_path.exists() {
            println!("⚠️  Aviso: workflow-enforcer.rs não encontrado");
            return;
        }

        if let Ok(content) = fs::read_to_string(&enforcer_path) {
            let lines: Vec<_> = content.lines().collect();
            let mut current_category = String::new();
            let mut current_source = String::new();

            for (i, line) in lines.iter().enumerate() {
                let trimmed = line.trim();

                // Detectar categoria
                if trimmed.starts_with("// SOURCE:") {
                    let re = Regex::new(r"SOURCE:\s*(.+?)\s*-\s*Section\s*(.+)").unwrap();
                    if let Some(caps) = re.captures(trimmed) {
                        current_source = caps[1].to_string();
                        current_category = self.categorize_rule(&current_source);
                    }
                }

                // Detectar patterns
                if trimmed.starts_with("const ") && trimmed.contains("PATTERNS") {
                    let re = Regex::new(r"const\s+(\w+_PATTERNS):\s*Vec<Regex>").unwrap();
                    if let Some(caps) = re.captures(trimmed) {
                        let pattern_name = &caps[1];
                        self.extract_pattern_array(&lines, i + 1, pattern_name, &current_category, &current_source);
                    }
                }
            }
        }

        self.report.metrics.total_patterns = self.report.blocking_patterns.len();
        println!("✅ Extraídos {} patterns de bloqueio", self.report.metrics.total_patterns);
    }

    fn extract_pattern_array(
        &mut self,
        lines: &[&str],
        start_index: usize,
        array_name: &str,
        category: &str,
        source: &str,
    ) {
        let mut in_array = false;
        let mut brace_count = 0;

        for (i, line) in lines.iter().enumerate().skip(start_index) {
            let trimmed = line.trim();

            if trimmed.starts_with("[") || trimmed.contains("vec![") {
                in_array = true;
                brace_count = trimmed.matches('[').count() as i32 - trimmed.matches(']').count() as i32;
            }

            if in_array {
                brace_count += trimmed.matches('[').count() as i32 - trimmed.matches(']').count() as i32;

                // Extrair pattern regex
                let re = Regex::new(r#"regex::Regex::new\(r#"([^"]+)"#\)"#).unwrap();
                if let Some(caps) = re.captures(trimmed) {
                    let pattern = &caps[1];
                    let description = self.extract_pattern_description(lines, i.saturating_sub(5), i);

                    self.report.blocking_patterns.push(BlockingPattern {
                        category: category.to_string(),
                        pattern: pattern.to_string(),
                        source: format!("{} - {}", source, array_name),
                        description,
                    });

                    // Atualizar métricas
                    match category {
                        "Segurança" => self.report.metrics.security_patterns += 1,
                        "Performance" => self.report.metrics.performance_patterns += 1,
                        "Arquitetura" => self.report.metrics.architecture_patterns += 1,
                        _ => {}
                    }
                }

                if brace_count <= 0 && (trimmed.contains("]") || trimmed.ends_with("];")) {
                    break;
                }
            }
        }
    }

    fn extract_pattern_description(&self, lines: &[&str], start: usize, end: usize) -> String {
        for i in start..=end.min(lines.len() - 1) {
            let line = lines[i].trim();
            if line.starts_with("// PROHIBITION:") {
                return line.replace("// PROHIBITION:", "").trim().to_string();
            }
        }
        "Pattern de bloqueio".to_string()
    }

    fn categorize_rule(&self, source: &str) -> String {
        if source.contains("Conformidade") || source.contains("OWASP") || source.contains("Security") {
            "Segurança".to_string()
        } else if source.contains("react-hooks") || source.contains("performance") {
            "Performance".to_string()
        } else if source.contains("API-convention") || source.contains("Arquitetura") {
            "Arquitetura".to_string()
        } else if source.contains("typescript") || source.contains("design-system") {
            "Qualidade".to_string()
        } else {
            "Geral".to_string()
        }
    }

    fn analyze_smart_components(&mut self) {
        println!("🔍 Analisando Smart Components...");

        let smart_components_path = self.nemesis_dir.join("smart-components.json");

        if !smart_components_path.exists() {
            println!("⚠️  Aviso: smart-components.json não encontrado");
            return;
        }

        match fs::read_to_string(&smart_components_path) {
            Ok(content) => {
                if let Ok(data) = serde_json::from_str::<serde_json::Value>(&content) {
                    if let Some(components) = data.get("smartComponents").and_then(|v| v.as_array()) {
                        for component in components {
                            if let Some(path) = component.as_str() {
                                let component_type = self.categorize_component(path);
                                self.report.smart_components.push(SmartComponent {
                                    path: path.to_string(),
                                    component_type,
                                });
                            }
                        }

                        self.report.metrics.smart_components = components.len();
                        println!("✅ Encontrados {} Smart Components", self.report.metrics.smart_components);
                    }
                }
            }
            Err(e) => {
                println!("⚠️  Aviso: Erro ao ler smart-components.json: {}", e);
            }
        }
    }

    fn categorize_component(&self, path: &str) -> String {
        if path.contains("/ui/") {
            "UI".to_string()
        } else if path.contains("/shared") {
            "Shared".to_string()
        } else if path.contains("/main-content") {
            "Main Content".to_string()
        } else if path.contains("/dashboard-layout") {
            "Layout".to_string()
        } else {
            "Other".to_string()
        }
    }

