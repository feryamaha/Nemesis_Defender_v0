    fn validate_system(&self) {
        println!("🔍 Validando sistema...");

        match Command::new("bun").args(&["lint"]).output() {
            Ok(output) if output.status.success() => {
                println!("✅ Lint validado");
            }
            _ => {
                println!("⚠️  Lint falhou - verificar código");
            }
        }

        match Command::new("bun").args(&["tsc", "--noEmit"]).output() {
            Ok(output) if output.status.success() => {
                println!("✅ TypeScript validado");
            }
            _ => {
                println!("⚠️  TypeScript falhou - verificar tipos");
            }
        }

        match Command::new("bun").arg("build").output() {
            Ok(output) if output.status.success() => {
                println!("✅ Build validado");
            }
            _ => {
                println!("⚠️  Build falhou - verificar build");
            }
        }
    }

    fn execute(&mut self) {
        println!("🚀 Iniciando análise completa do Nemesis Enforcement System...\n");

        self.analyze_nemesis_structure();
        self.extract_blocking_patterns();
        self.analyze_smart_components();
        self.generate_benefits();
        self.generate_report();
        self.validate_system();

        println!("\n✅ Análise concluída com sucesso!");
        println!("📊 Relatório gerado com {} patterns mapeados", self.report.metrics.total_patterns);
        println!("🎯 PRs prontas para aprovação automática sem retrabalho");
    }
}

fn main() {
    let mut analyzer = NemesisAnalyzer::new();
    analyzer.execute();
